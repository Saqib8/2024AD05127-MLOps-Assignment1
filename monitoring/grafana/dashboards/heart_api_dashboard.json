{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["mlops", "heart-disease"],
  "title": "Heart Disease API Monitoring",
  "uid": "heart-disease-api",
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "5s",
  "panels": [
    {
      "type": "stat",
      "title": "Total API Requests",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(api_requests_total)", "legendFormat": "requests" }
      ]
    },
    {
      "type": "stat",
      "title": "Total Predictions Served",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(heart_predictions_total)", "legendFormat": "predictions" }
      ]
    },
    {
      "type": "piechart",
      "title": "Predictions by Class",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "heart_predictions_total", "legendFormat": "class {{prediction}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Rate (per sec, by endpoint)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (endpoint) (rate(api_requests_total[1m]))", "legendFormat": "{{endpoint}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "/predict Latency (p50 / p95)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(predict_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(predict_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }
      ]
    }
  ]
}
